{
  "name": "rose-n-petals",
  "version": "1.0.0",
  "description": "Rose n Petals Node Web Service",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "bundle": "npx esbuild js/bundle-entry.js --bundle --format=iife --minify --outfile=dist/bundle.js",
    "build": "npm run generate-sitemap && npm run bundle",
    "prerender": "node scripts/prerender.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "esbuild": "^0.21.5"
  }
}
